<mvc:View
    controllerName="odataproject.controller.OrderList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="Northwind Orders List" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <!-- Orders List Table -->
            <Table 
                id="ordersTable"
                headerText="All Customer Orders"
                items="{/Orders}"
                growing="true"
                growingThreshold="20"
                class="sapUiResponsiveMargin">
                <columns>
                    <Column>
                        <Text text="Order ID" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Customer ID" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Order Date" />
                    </Column>
                    <Column minScreenWidth="Desktop" demandPopin="true">
                        <Text text="Ship Name" />
                    </Column>
                    <Column hAlign="End">
                        <Text text="Action" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onOrderSelect">
                        <cells>
                            <ObjectIdentifier title="{OrderID}" />
                            <Text text="{CustomerID}" />
                            <Text text="{path: 'OrderDate', type: 'sap.ui.model.type.Date', formatOptions: {style: 'medium'}}" />
                            <Text text="{ShipName}" />
                            <Button text="View Details" type="Emphasized" press="onOrderSelect" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
