<mvc:View controllerName="odatacrud.controller.View1"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
    <content>
     <!-- Toolbar with inputs and Add button (uses only sap.m) -->
      <OverflowToolbar id="idOToolbar" design="Transparent" class="sapUiSmallMargin">
        <Label id="idLblName" text="Name" />
        <Input id="inpName" width="200px" />
        <Label id="idLblDesc" text="Description" />
        <Input id="inpDescription" width="250px" />
        <Label id="idLblPrice" text="Price" />
        <Input id="inpPrice" width="120px" />
        <Label id="idLblRating" text="Rating" />
        <Input id="inpRating" width="120px" />
        <ToolbarSpacer id="idToolbarSpacer"/>
        <Button id="btnAdd" text="Add" type="Emphasized" press="onAdd"/>
      </OverflowToolbar>
    <Table id="idProducts" items="{/results}">
     <headerToolbar>
          <Toolbar id="idToolbar">
            <Title id="idTitle" text="Products" />
          </Toolbar>
        </headerToolbar>
    <columns> 
        <Column id="idIDCol">
            <Text id="idColID" text="ID"></Text>
        </Column>
         <Column id="idNameCol">
            <Text id="idColName" text="Name"></Text>
        </Column>
         <Column id="idDescriptionCol">
            <Text id="idColDescription" text="Description"></Text>
        </Column>
         <Column id="idPriceCol">
            <Text id="idColPrice" text="Price"></Text>
        </Column>
        <Column id="idRatingCol">
            <Text id="idColRating" text="Rating"></Text>
        </Column>
         <Column id="idActionsCol">
            <Text id="idColActions" text="Actions"></Text>
        </Column>
    </columns>
    <items>
    <ColumnListItem id="idColList">
        <cells>
            <Text id="idID" text="{ID}" />
            <Text id="idName" text="{Name}"/>
            <Text id="idDescription" text="{Description}"/>
            <Text id="idPrice" text="{Price}" />
            <Input id="idRating" value="{Rating}" editable ="false" />
            <HBox id="idHBox">
                <Button id="idEdit" text="Edit" press="onEdit"></Button>
                <Button id="idDuplicate" text="Duplicate" press="onDuplicate" class = "sapUiSmallMarginBeginEnd"></Button>
                <Button id="idDelete" text="Delete" press="onDelete"  type="Reject"></Button>
            </HBox>
        </cells>
    </ColumnListItem>
    </items>
    </Table>
    </content>
    </Page>
</mvc:View>